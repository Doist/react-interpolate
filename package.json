{
  "name": "@doist/react-interpolate",
  "version": "2.2.2",
  "description": "A string interpolation component that formats and interpolates a template string in a safe way",
  "keywords": [
    "format",
    "interpolate",
    "react",
    "string",
    "template",
    "text"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doist/react-interpolate.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "check": "npm run check:format && npm run check:lint && npm run typecheck",
    "check:format": "oxfmt --check",
    "check:lint": "oxlint",
    "lint": "npm run check:lint",
    "typecheck": "tsc --project tsconfig.json",
    "check:package": "node package-checks/smoke.cjs && tsc --project package-checks/tsconfig.esm.json --noEmit && tsc --project package-checks/tsconfig.cjs.json --noEmit",
    "test:package": "npm run check:package",
    "build": "tsdown && npm run check:package",
    "fix": "npm run fix:format && npm run fix:lint",
    "fix:format": "oxfmt",
    "fix:lint": "oxlint --fix",
    "prettify": "npm run fix:format"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "jsdom": "29.1.1",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": "^10.0.0 || ^11.0.0"
  }
}
